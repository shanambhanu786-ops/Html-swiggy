<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Swiggy Clone</title>
</head>
<body>
<!-- Header -->
    <header>
        <h1>Swiggy Clone</h1>
        <nav>
            <a href="#">Home</a> |
            <a href="#">Restaurants</a> |
            <a href="#">Offers</a> |
            <a href="#">Cart</a> |
            <a href="#">Login</a>
        </nav>
    </header>
    <hr>
    <!-- Hero Section -->
    <section>
        <h2>Order Food Online</h2>
        <p>Discover restaurants and order your favorite meals.</p>
        <form>
            <input type="text" placeholder="Enter your location">
            <input type="text" placeholder="Search for food or restaurant">
            <button type="submit">Search</button>
        </form>
    </section>
    <hr>
    <!-- Categories -->
    <section>
        <h2>Food Categories</h2>
        <ul>
            <li>Pizza</li>
            <li>Burger</li>
            <li>Biryani</li>
            <li>Dosa</li>
            <li>Chinese</li>
            <li>Desserts</li>
        </ul>
    </section>
    <hr>
    <!-- Restaurants -->
    <section>
        <h2>Popular Restaurants</h2>

        <article>
            <h3>Paradise Biryani</h3>
            <p>⭐ 4.5 | Biryani | 30 mins</p>
            <button>View Menu</button>
        </article>

        <article>
            <h3>Domino's Pizza</h3>
            <p>⭐ 4.4 | Pizza | 25 mins</p>
            <button>View Menu</button>
        </article>
        <article>
            <h3>KFC</h3>
            <p>⭐ 4.3 | Chicken | 20 mins</p>
            <button>View Menu</button>
        </article>
    </section>
    <hr>
    <!-- Cart -->
    <section>
        <h2>My Cart</h2>
        <p>No items added.</p>
        <button>Checkout</button>
    </section>
    <hr>
    <!-- Footer -->
    <footer>
        <p>&copy; 2026 Swiggy Clone. Built for learning purposes.</p>
    </footer>
</body>
</html>
